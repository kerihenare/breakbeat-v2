# --- App ---
NODE_ENV=development
PORT=3000

# --- Backing services ---
# Host-oriented defaults (for `pnpm dev` on the host). The web/worker processes
# run on the host (node --import); docker-compose provides the backing services
# (postgres, redis, otel-lgtm, bugsink) only.
DATABASE_URL=postgres://breakbeat:breakbeat@localhost:5432/breakbeat
REDIS_URL=redis://localhost:6379

# --- Observability (OpenTelemetry → otel-lgtm; ADR 0004 / PRD 8) ---
# The OTLP HTTP/proto Collector endpoint (docker-compose otel-lgtm). Traces +
# metrics export here (fail-soft: dropped silently if it is down). OTEL_SERVICE_NAME
# is set per entrypoint by the start scripts (breakbeat-web / breakbeat-worker).
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# Set to true to run with telemetry OFF (the pipeline is byte-identical). Tests/CI set this.
OTEL_SDK_DISABLED=

# --- Error reporting (Bugsink) ---
# Create a project in Bugsink (http://localhost:8000), then paste its DSN here.
# Left blank, the app still boots; error reporting is simply disabled.
SENTRY_DSN=

# --- External APIs (optional; a keyless clone still boots) ---
# Anthropic (Claude Haiku classification, entity verification, and web-search backstop — one key, three signals) — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
ANTHROPIC_BACKSTOP_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_HAIKU_MODEL=claude-haiku-4-5-20251001  # analyze snippet gates + the fused full-text call (ADR 0003)
ANTHROPIC_ANALYZE_TIMEOUT_MS=15000               # per-call timeout for the analyze Haiku calls
# Tavily search — https://app.tavily.com/home
TAVILY_API_KEY=
TAVILY_TIMEOUT_MS=10000
# BrandFetch (identity resolution and Brand Context: description, industry, aliases) — https://brandfetch.com/
BRANDFETCH_API_KEY=
BRANDFETCH_CLIENT_ID=
BRANDFETCH_BASE_URL=https://api.brandfetch.io/v2
BRANDFETCH_TIMEOUT_MS=5000

# --- Resolve stage homepage fetch (the one true outbound fetch) ---
HOMEPAGE_FETCH_TIMEOUT_MS=5000

# --- Search stage (ADR 0002 — one low-yield threshold governs both escalations) ---
SEARCH_LOW_YIELD_THRESHOLD=10

# --- Filter stage (PRD 4 — deterministic heuristic + Collapse knobs, Aglow-tuned) ---
FILTER_HORIZON_MONTHS=36
FILTER_COLLAPSE_WINDOW_DAYS=14
FILTER_MIN_DISTINCTIVE_TOKENS=5
FILTER_MIN_CLUSTER_DOMAINS=2

# --- Analyze stage (PRD 5 — Verify / Classify / Enhance; Aglow-tuned cutoffs 25/40/70) ---
ANALYZE_SNIPPET_T_EXCLUDE=25      # LENIENT snippet-pass exclude cutoff (cost gate)
ANALYZE_FULL_TEXT_T_EXCLUDE=40    # STRICTER full-text exclude cutoff (the precision call)
ANALYZE_T_VERIFIED=70             # at/above → verified (both passes)
ANALYZE_EXTRACT_CONCURRENCY=5     # bounded per-Result fan-out
ANALYZE_TAKEAWAY_MAX_LENGTH=400   # schema cap on the one validated free-text field

# --- Summarise stage (PRD 6 — Job-level digest, one Haiku call per Job) ---
SUMMARISE_MODEL=claude-haiku-4-5-20251001   # the Haiku model id for the one-per-Job digest call
SUMMARISE_TIMEOUT_MS=20000                  # per-call timeout for the digest
SUMMARISE_DIGEST_MAX_LENGTH=1200            # soft cap on the digest length (≤ the schema hard ceiling)
