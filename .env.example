# --- App ---
NODE_ENV=development
PORT=3000

# --- Backing services ---
# Host-oriented defaults (for `pnpm dev` on the host). The web/worker processes
# run on the host (node --import); docker-compose provides the backing services
# (postgres, redis, otel-lgtm, bugsink) only.
DATABASE_URL=postgres://breakbeat:breakbeat@localhost:5432/breakbeat
REDIS_URL=redis://localhost:6379

# --- Error reporting (Bugsink) ---
# Create a project in Bugsink (http://localhost:8000), then paste its DSN here.
# Left blank, the app still boots; error reporting is simply disabled.
SENTRY_DSN=

# --- External APIs (optional; a keyless clone still boots) ---
# Anthropic (Claude Haiku classification, entity verification, and web-search backstop — one key, three signals) — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
# Tavily search — https://app.tavily.com/home
TAVILY_API_KEY=
# BrandFetch (identity resolution and Brand Context: description, industry, aliases) — https://brandfetch.com/
BRANDFETCH_API_KEY=
BRANDFETCH_CLIENT_ID=
