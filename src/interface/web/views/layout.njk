<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>{% block title %}Breakbeat{% endblock %}</title>
		<link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'><rect width='32' height='32' rx='7' fill='%23292a2a'/><circle cx='16' cy='16' r='5' fill='%2346bbff'/></svg>" />
		<link rel="stylesheet" href="/static/styles.css" />
	</head>
	<body class="min-h-screen antialiased">
		<header class="border-b border-newsprint-border">
			<div class="mx-auto flex max-w-5xl items-center justify-between px-6 py-4">
				<a href="/" class="text-lg font-semibold tracking-tight text-ink-strong focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent-blue">Breakbeat</a>
				<nav>
					<a href="/searches" class="text-sm font-medium text-ink-muted hover:text-ink focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent-blue">Searches</a>
				</nav>
			</div>
		</header>
		<main class="mx-auto max-w-5xl px-6 py-10">{% block content %}{% endblock %}</main>
	</body>
</html>
