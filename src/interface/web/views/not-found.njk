{% extends "layout.njk" %}
{% block title %}Not found — Breakbeat{% endblock %}
{% block content %}
<div class="flex min-h-[50vh] flex-col items-center justify-center text-center">
	<h1 class="text-3xl font-semibold tracking-tight">Job not found</h1>
	<p class="mt-2 text-sm text-ink-toned">That search doesn't exist (or was never started).</p>
	<a href="/" class="mt-6 rounded-lg bg-ink-control px-4 py-2 text-sm font-medium text-newsprint-surface hover:bg-ink">Start a new search</a>
</div>
{% endblock %}
